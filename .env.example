# Purpose of this file:
# - Template for local environment configuration.
# - Copy this file to ".env" and replace placeholder values with real secrets.
#
# Setup steps:
# 1) Copy ".env.example" to ".env" in the project root.
# 2) Fill database credentials for your local PostgreSQL instance.
# 3) Generate a Base64 JWT key (at least 256-bit) and set it below.
# 4) Keep ".env" out of version control.
#
# Database connection used by Spring datasource placeholders in application.yml.
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# JWT settings used by JwtService for token signing and expiration.
# "application.security.jwt.secret-key" is the signing key (Base64 encoded).
# "application.security.jwt.expiration" is token lifetime in milliseconds.
JWT_SECRET_KEY=
JWT_EXPIRATION=
JWT_ISSUER=
JWT_AUDIENCE=
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_METHODS=
CORS_ALLOWED_HEADERS=
AUTH_RATE_LIMIT_MAX_ATTEMPTS=
AUTH_RATE_LIMIT_WINDOW_SECONDS=
